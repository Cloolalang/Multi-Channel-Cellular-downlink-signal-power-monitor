        "func": "// msg.payload contains: \"+QRXFTM: -878, -87\\n\\nOK\"\n\nconst input = msg.payload;\n\n// Regex breakdown:\n// \\+QRXFTM:    Matches the header\n// -?\\d+        Matches the first number (e.g., -878)\n// ,\\s* Matches the comma and any whitespace\n// (-?\\d+)      Captures the second number in a group\nconst match = input.match(/\\+QRXFTM:\\s*-?\\d+,\\s*(-?\\d+)/);\n\nif (match && match[1]) {\n    // Convert the captured string \"-87\" to a number\n    msg.payload = parseInt(match[1]);\n    return msg;\n}// else {\n    // Optional: handle cases where the value isn't found\n //   node.warn(\"RSSI value not found in response\");\n  //  return null; \n//}",
