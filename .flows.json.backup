    {
        "id": "3bb7732d9334548a",
        "type": "function",
        "z": "0dc09b3345a4941d",
        "name": "function 34",
        "func": "// 1. Get the storage object from context\nlet signals = context.get('signals') || {};\n\n// 2. Handle a manual reset (Optional but recommended)\nif (msg.topic === \"reset\") {\n    context.set('signals', {});\n    return null; \n}\n\n// 3. Store the incoming signal\n// We assume any incoming topic that isn't \"reset\" is a valid signal\nif (typeof msg.payload === 'number' || !isNaN(msg.payload)) {\n    signals[msg.topic] = parseFloat(msg.payload);\n    context.set('signals', signals);\n}\n\n// 4. Get all currently stored signals\nlet signalKeys = Object.keys(signals);\n\n// 5. Only calculate if we have at least one signal\nif (signalKeys.length > 0) {\n    let total_mw = 0;\n\n    // Sum the linear power of all signals currently in the object\n    for (let topic of signalKeys) {\n        let dbm = signals[topic];\n        total_mw += Math.pow(10, dbm / 10);\n    }\n\n    // Convert back to dBm\n    let composite_dbm = 10 * Math.log10(total_mw);\n\n    // Prepare output\n    msg.payload = parseFloat(composite_dbm.toFixed(2));\n    \n    // Add metadata so you know how many signals were summed\n    msg.signalCount = signalKeys.length;\n    msg.sources = signalKeys; \n\n    return msg;\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 3350,
        "y": 160,
        "wires": [
            [
                "36106b779a820cb3"
            ]
        ]
    },
