    {
        "id": "dfbd20e56eec50bb",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "convert E-Utra BW to Quectel BW",
        "func": "// Map Input (MHz) to Output (Index)\n// 5MHz  -> 2\n// 10MHz -> 3\n// 15MHz -> 4\n// 20MHz -> 5\n\nconst bwMap = {\n    5: 2,\n    10: 3,\n    15: 4,\n    20: 5\n};\n\nlet inputBW = parseInt(msg.payload);\n\nif (bwMap.hasOwnProperty(inputBW)) {\n    msg.payload = bwMap[inputBW];\n    return msg;\n} else {\n    node.error(\"Invalid Bandwidth: \" + inputBW + \"MHz. Expected 5, 10, 15, or 20.\");\n    return null;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 820,
        "wires": [
            [
                "eca080c910896dcb"
            ]
        ]
    },
