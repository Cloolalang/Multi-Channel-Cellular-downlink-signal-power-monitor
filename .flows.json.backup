    },
    {
        "id": "b4a2d73892b270cf",
        "type": "function",
        "z": "0dc09b3345a4941d",
        "name": "function 6",
        "func": "// Get existing stored values from context\nlet signal1 = context.get('signal1') || null;\nlet signal2 = context.get('signal2') || null;\n\n// Store the incoming value based on your specific topics\nif (msg.topic === \"6300\") {\n    signal1 = msg.payload;\n    context.set('signal1', signal1);\n} else if (msg.topic === \"323\") {\n    signal2 = msg.payload;\n    context.set('signal2', signal2);\n}\n\n// Only calculate if we have both values\nif (signal1 !== null && signal2 !== null) {\n    // 1. Convert dBm (log) to mW (linear)\n    let p1_mw = Math.pow(10, signal1 / 10);\n    let p2_mw = Math.pow(10, signal2 / 10);\n    \n    // 2. Sum the power in milliwatts\n    let total_mw = p1_mw + p2_mw;\n    \n    // 3. Convert total back to dBm\n    let composite_dbm = 10 * Math.log10(total_mw);\n    \n    // Return ONLY the number as the payload\n    msg.payload = Number(composite_dbm.toFixed(2));\n    \n    return msg;\n}\n\n// Stop the flow until both signals have arrived\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1640,
        "y": 80,
        "wires": [
            [
                "ca9281cec8f0d5d0"
            ]
        ]
    },
