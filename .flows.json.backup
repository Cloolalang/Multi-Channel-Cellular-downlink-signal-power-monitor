    {
        "id": "de4e6ec13a7274ce",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "function 79",
        "func": "// 1. Retrieve the global variable 'chartlow'\nlet chartlow = global.get(\"chartlow\") || -25;\n\n// 2. Get the \"startTime\" from the node's local memory\nlet startTime = context.get(\"startTime\") || null;\n\nif (msg.payload < chartlow) {\n    if (!startTime) {\n        // This is the first time it dropped below threshold\n        startTime = Date.now();\n        context.set(\"startTime\", startTime);\n        return msg; // Continue flow for now; the 30s haven't passed\n    }\n    \n    // Check if 40,000 milliseconds (40 seconds) have elapsed\n    if (Date.now() - startTime > 40000) {\n        return null; // Stop the flow (Condition true for > 30s)\n    }\n    \n    return msg; // Condition is true, but hasn't reached 30s yet\n} else {\n    // 3. Reset the timer if the value goes back above the threshold\n    context.set(\"startTime\", null);\n    return msg; \n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 4310,
        "y": 2200,
        "wires": [
            [
                "d6f8e14924911924",
                "5012ee6464976e42",
                "6845e7e3e31f7004"
            ]
        ]
    },
