    {
        "id": "16e51c3034a2d322",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "sends AT command two times as a work around",
        "func": "// Retrieve values from global context\nconst earfcn = global.get(\"ch2earfcn\") || 0;\nconst band = global.get(\"ch2band\") || 0;\nconst bw = global.get(\"ch2bw\") || 0;\n\n// Static parameters\nconst mode = 1;\nconst antenna = 0;\nconst lnaState = 1;\n\n// Construct the command\nconst atCommand = `AT+QRXFTM=${mode},${band},${earfcn},${antenna},${lnaState},${bw}\\r\\n`;\n\n// 1. Send the first message immediately\nmsg.payload = atCommand;\nnode.send(msg);\n\n// 2. Schedule the second message after 1000ms\n// We use a clone of the message object to avoid side effects\nsetTimeout(function() {\n    const msg2 = RED.util.cloneMessage(msg);\n    msg2.payload = atCommand;\n    node.send(msg2);\n}, 1000);\n\n// Return null so the node doesn't send a third \"automatic\" message\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 3220,
        "y": 1460,
        "wires": [
            [
                "8522e5c5530fc0d6"
            ]
        ]
    },
