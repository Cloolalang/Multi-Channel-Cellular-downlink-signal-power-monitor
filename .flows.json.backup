    {
        "id": "6b8e101d1dcdafe4",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "function 128",
        "func": "// 1. Get the attenuation value from global context (default to 0 if not set)\nconst attenuation = global.get(\"atten0\") || 0;\n\n// 2. Ensure the input payload is treated as a number\nconst inputVal = parseFloat(msg.payload);\n\n// 3. Perform the subtraction\n// Result = Input - Attenuation\nmsg.payload = inputVal + attenuation;\n\n// 4. Return the updated message\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 4110,
