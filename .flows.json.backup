        "id": "c92c7bcf87a74c96",
        "type": "function",
        "z": "0dc09b3345a4941d",
        "name": "function 12",
        "func": "// Example inputs: \n// msg.param1 = 5;\n// msg.param2 = 12345;\n\nconst p1 = msg.param1;\nconst p2 = msg.param2;\n\n\n// Construct the string using a Template Literal\nmsg.payload = `AT%XRFTEST=3,1,${p1},${p2},-65,1,1\\r\\n`;\n\nreturn msg;",
