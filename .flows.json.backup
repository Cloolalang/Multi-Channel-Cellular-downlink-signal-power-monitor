    {
        "id": "2eaee63411fbbb3d",
        "type": "function",
        "z": "0dc09b3345a4941d",
        "name": "function 8",
        "func": "let inputString = msg.payload;\nlet matches = inputString.match(/-?\\d+/g);\n\nif (matches && matches.length >= 2) {\n    let snr_db = parseInt(matches[0]) / 16;\n    let power_dbm = parseInt(matches[1]) / 256;\n\n    // Create two separate message objects\n    let msgSNR = { payload: Number(snr_db.toFixed(2)) };\n    let msgPower = { payload: Number(power_dbm.toFixed(2)) };\n\n    // Return them as an array: [Output 1, Output 2]\n    return [msgSNR, msgPower];\n}\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1180,
        "y": 2160,
        "wires": [
            [],
            [
                "7b419277a669529d"
            ]
        ]
    },
