    {
        "id": "a6c7cf45f5605ec2",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "sends AT command two times as a work around",
        "func": "// Retrieve values from global context\nconst earfcn = global.get(\"ch12earfcn\") || 0;\nconst band = global.get(\"ch12band\") || 0;\nconst bw = global.get(\"ch12bw\") || 0;\n\n// Static parameters\nconst mode = 1;\nconst antenna = 0;\nconst lnaState = 1;\n\n// Construct the command\nconst atCommand = `AT+QRXFTM=${mode},${band},${earfcn},${antenna},${lnaState},${bw}\\r\\n`;\n\n// 1. Send the first message immediately\nmsg.payload = atCommand;\nnode.send(msg);\n\n// 2. Schedule the second message after 1000ms\n// We use a clone of the message object to avoid side effects\nsetTimeout(function() {\n    const msg2 = RED.util.cloneMessage(msg);\n    msg2.payload = atCommand;\n    node.send(msg2);\n}, 1000);\n\n// Return null so the node doesn't send a third \"automatic\" message\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 3200,
        "y": 5500,
        "wires": [
            [
                "9f41b936692927eb"
            ]
        ]
    },
    {
        "id": "9f41b936692927eb",
        "type": "serial request",
        "z": "2d81681b3a2dcca8",
        "name": "",
        "serial": "5c5a9d2d578a7701",
        "x": 3500,
        "y": 5500,
        "wires": [
            [
                "4c66e6ba75ec26ee",
                "aae61faa57812e9e"
            ]
        ]
    },
    {
        "id": "cfc08773a2d42964",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "sends AT command two times as a work around",
        "func": "// Retrieve values from global context\nconst earfcn = global.get(\"ch13earfcn\") || 0;\nconst band = global.get(\"ch13band\") || 0;\nconst bw = global.get(\"ch13bw\") || 0;\n\n// Static parameters\nconst mode = 1;\nconst antenna = 0;\nconst lnaState = 1;\n\n// Construct the command\nconst atCommand = `AT+QRXFTM=${mode},${band},${earfcn},${antenna},${lnaState},${bw}\\r\\n`;\n\n// 1. Send the first message immediately\nmsg.payload = atCommand;\nnode.send(msg);\n\n// 2. Schedule the second message after 1000ms\n// We use a clone of the message object to avoid side effects\nsetTimeout(function() {\n    const msg2 = RED.util.cloneMessage(msg);\n    msg2.payload = atCommand;\n    node.send(msg2);\n}, 1000);\n\n// Return null so the node doesn't send a third \"automatic\" message\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 3200,
        "y": 5900,
        "wires": [
            [
                "ab776678ba1d1701"
            ]
        ]
    },
    {
        "id": "ab776678ba1d1701",
        "type": "serial request",
        "z": "2d81681b3a2dcca8",
        "name": "",
        "serial": "5c5a9d2d578a7701",
        "x": 3500,
        "y": 5900,
        "wires": [
            [
                "b0628bff14803daf",
                "aae61faa57812e9e"
            ]
        ]
    },
    {
        "id": "4c66e6ba75ec26ee",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "function 144",
        "func": "// msg.payload contains: \"+QRXFTM: -878, -87\\n\\nOK\"\n\nconst input = msg.payload;\n\n// Regex breakdown:\n// \\+QRXFTM:    Matches the header\n// -?\\d+        Matches the first number (e.g., -878)\n// ,\\s* Matches the comma and any whitespace\n// (-?\\d+)      Captures the second number in a group\nconst match = input.match(/\\+QRXFTM:\\s*-?\\d+,\\s*(-?\\d+)/);\n\nif (match && match[1]) {\n    // Convert the captured string \"-87\" to a number\n    msg.payload = parseInt(match[1]);\n    return msg;\n}// else {\n    // Optional: handle cases where the value isn't found\n //   node.warn(\"RSSI value not found in response\");\n  //  return null; \n//}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 3850,
        "y": 5500,
        "wires": [
            [
                "2598c9dccdd151fb",
                "6ae2c76ef688935e"
            ]
        ]
    },
    {
        "id": "b0628bff14803daf",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "function 145",
        "func": "// msg.payload contains: \"+QRXFTM: -878, -87\\n\\nOK\"\n\nconst input = msg.payload;\n\n// Regex breakdown:\n// \\+QRXFTM:    Matches the header\n// -?\\d+        Matches the first number (e.g., -878)\n// ,\\s* Matches the comma and any whitespace\n// (-?\\d+)      Captures the second number in a group\nconst match = input.match(/\\+QRXFTM:\\s*-?\\d+,\\s*(-?\\d+)/);\n\nif (match && match[1]) {\n    // Convert the captured string \"-87\" to a number\n    msg.payload = parseInt(match[1]);\n    return msg;\n}// else {\n    // Optional: handle cases where the value isn't found\n //   node.warn(\"RSSI value not found in response\");\n  //  return null; \n//}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
