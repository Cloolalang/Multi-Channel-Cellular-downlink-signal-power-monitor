    {
        "id": "ef4b932de3a3b35b",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "d": true,
        "name": "function 109",
        "func": "// 1. Get the attenuation value from global context (default to 0 if not set)\nconst attenuation = global.get(\"EC25atten\") || 0;\n\n// 2. Ensure the input payload is treated as a number\nconst inputVal = parseFloat(msg.payload);\n\n// 3. Perform the subtraction\n// Result = Input - Attenuation\nmsg.payload = inputVal + attenuation;\n\n// 4. Return the updated message\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
