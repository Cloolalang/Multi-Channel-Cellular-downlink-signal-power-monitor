        "name": "50% loaded 10mhz",
        "inputMsgField": "payload",
        "outputMsgField": "payload",
        "operation": "sub",
        "constant": "27.8",
        "round": false,
        "truncate": false,
        "decimals": 0,
        "decimals2": 0,
