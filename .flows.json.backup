    {
        "id": "8b9698a9ccb08844",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "function 153",
        "func": "// 1. Get the storage object from context\nlet signals = context.get('signals') || {};\n\n// 2. Handle a manual reset\nif (msg.topic === \"reset\") {\n    context.set('signals', {});\n    return null;\n}\n\n// 3. Store the incoming signal\nif (typeof msg.payload === 'number' || !isNaN(msg.payload)) {\n    signals[msg.topic] = parseFloat(msg.payload);\n    context.set('signals', signals);\n}\n\n// 4. Count enabled channels from global context (ch0control ... ch13control)\nlet enabledCount = 0;\nfor (let i = 0; i <= 13; i++) {\n    if (global.get(`ch${i}control`) === true) {\n        enabledCount++;\n    }\n}\n\n// 5. Get all currently stored signals\nlet signalKeys = Object.keys(signals);\n\n// 6. Only calculate if we have at least one signal\nif (signalKeys.length > 0) {\n    let total_mw = 0;\n\n    // Sum the linear power (mW)\n    for (let topic of signalKeys) {\n        let dbm = signals[topic];\n        total_mw += Math.pow(10, dbm / 10);\n    }\n\n    // Convert back to dBm for Output 1\n    let composite_dbm = 10 * Math.log10(total_mw);\n\n    // Create message for Output 1 (dBm)\n    let msg1 = {\n        topic: \"composite_dbm\",\n        payload: parseFloat(composite_dbm.toFixed(2)),\n        signalCount: enabledCount,\n        sources: signalKeys\n    };\n\n    // Create message for Output 2 (Total mW)\n    let msg2 = {\n        topic: \"total_mw\",\n        payload: parseFloat(total_mw.toFixed(4)) // Adjust decimal places as needed\n    };\n\n    // Create message for Output 3 (Enabled channel count as int)\n    let msg3 = {\n        topic: \"signal_count\",\n        payload: enabledCount\n    };\n\n    // Return an array: [Output 1, Output 2, Output 3]\n    return [msg1, msg2, msg3];\n}\n\nreturn null;",
        "outputs": 3,
