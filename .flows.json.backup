    {
        "id": "53312f3eff8a0fe2",
        "type": "function",
        "z": "2d81681b3a2dcca8",
        "name": "function 126",
        "func": "// 1. Retrieve the values using exact Case-Sensitive names\nconst gMin  = global.get(\"gMin\");\nconst gMax  = global.get(\"gMax\");\nconst gSeg1 = global.get(\"gSeg1\");\nconst gSeg2 = global.get(\"gSeg2\");\n\n// 2. Map them to the ui_control object\n// We provide fallback numbers just in case a global isn't set\nmsg.ui_control = {\n    \"min\":  gMin  !== undefined ? gMin  : 14,\n    \"max\":  gMax  !== undefined ? gMax  : 18,\n    \"seg1\": gSeg1 !== undefined ? gSeg1 : 15,\n    \"seg2\": gSeg2 !== undefined ? gSeg2 : 17\n};\n\n// 3. Return the whole message\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
