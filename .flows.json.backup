        "type": "function",
        "z": "0dc09b3345a4941d",
        "name": "function 14",
        "func": "// Retrieve p1 from the incoming message\nconst p1 = msg.param1;\n\n// Retrieve p2 from the global context variable named \"p\"\nconst p2 = global.get(\"p\");\n\n// Construct the string: \n// The command replaces the 2nd and 4th parameters as requested\nmsg.payload = `AT%XRFTEST=3,1,${p1},${p2},-65,1,1\\r\\n`;\n\nreturn msg;",
