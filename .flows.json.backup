        "name": "function 73",
        "func": "// Get the global variable 'atten', default to 0 if not set\nconst atten = global.get(\"atten\") || 0;\n\n// Subtract atten from the input number\nmsg.payload = msg.payload + atten;\n\nreturn msg;\n",
